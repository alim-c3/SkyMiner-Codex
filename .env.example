# SkyMiner Environment Configuration
# Copy this file to .env and fill in values

# Override the config file path (optional)
# SKYMINER_CONFIG_PATH=config/default.yaml

# Override pipeline mode: "local" or "live"
# SKYMINER_MODE=local

# Override log level: DEBUG, INFO, WARNING, ERROR
# SKYMINER_LOG_LEVEL=INFO

# Override database path
# SKYMINER_DB_PATH=outputs/skyminer.sqlite
